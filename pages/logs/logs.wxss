@import "../../app.wxss";

page {
  background: linear-gradient(180deg, #f4f6fb 0%, #eef8f2 100%);
}

.page {
  min-height: 100vh;
  padding: 14rpx 20rpx 36rpx;
  box-sizing: border-box;
}

.page-shell {
  min-height: calc(100vh - 28rpx);
  border-radius: 42rpx;
  border: 1rpx solid rgba(229, 219, 201, 0.92);
  background:
    radial-gradient(rgba(255, 214, 214, 0.42) 3rpx, transparent 3.5rpx) 0 0 / 76rpx 76rpx,
    linear-gradient(180deg, #fffaf4 0%, #fffdf8 58%, #eef8f2 100%);
  padding: 26rpx;
  box-sizing: border-box;
}

.hero-card {
  border-radius: 42rpx;
  border: 2rpx solid rgba(226, 210, 183, 0.9);
  background: linear-gradient(125deg, #ffe8a4 0%, #f8f3d5 52%, #d8eefb 100%);
  padding: 30rpx 30rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 28rpx rgba(92, 88, 76, 0.08);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-wrap: wrap;
}

.hero-title {
  color: #26313a;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.08;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #697681;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.status-settled {
  background: #e6f6ef;
  color: #178160;
}

.hero-date {
  margin-top: 26rpx;
  color: #64727d;
  font-size: 28rpx;
  font-weight: 900;
}

.hero-image {
  width: 176rpx;
  height: 176rpx;
  flex: none;
}

.summary-card {
  margin-top: 22rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.84);
  padding: 26rpx 28rpx 22rpx;
  box-sizing: border-box;
}

.summary-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-copy {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  flex-wrap: wrap;
  min-width: 0;
}

.summary-label {
  color: #73808c;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.summary-amount {
  color: #27313a;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 0.95;
}

.summary-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex: none;
}

.summary-link {
  padding: 15rpx 22rpx;
  border-radius: 999rpx;
  background: #dff0ff;
  color: #3774ad;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.summary-sub-link {
  color: #71808a;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
}

.summary-meta {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 246, 0.94);
  color: #33404b;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.primary-entry {
  width: 340rpx;
  height: 96rpx;
  margin: 34rpx auto 0;
  border-radius: 34rpx;
  background: #2c3640;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 96rpx;
  box-shadow: 0 14rpx 28rpx rgba(37, 46, 55, 0.18);
}

.primary-entry::after,
.manager-add-btn::after {
  border: 0;
}

.detail-section {
  margin-top: 48rpx;
}

.detail-section-title {
  color: #27313a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.detail-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-section-action-row {
  display: flex;
  gap: 12rpx;
  flex: none;
}

.filter-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #dff0ff;
  color: #3573ae;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.member-card,
.expense-card,
.fund-card,
.member-manager,
.empty-card {
  margin-top: 18rpx;
  border-radius: 30rpx;
  border: 2rpx solid #eadfce;
  background: rgba(255, 255, 255, 0.92);
  box-sizing: border-box;
}

.member-card {
  padding: 26rpx;
  box-shadow: 0 12rpx 24rpx rgba(101, 95, 85, 0.08);
}

.member-stack,
.expense-mini-stack {
  display: flex;
  align-items: center;
}

.member-avatar,
.member-avatar-small,
.expense-mini-avatar {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 4rpx solid #fffdf7;
  box-sizing: border-box;
  color: #25313b;
  font-weight: 900;
}

.member-avatar {
  width: 74rpx;
  height: 74rpx;
  margin-left: -12rpx;
  font-size: 26rpx;
  box-shadow: 0 6rpx 12rpx rgba(41, 44, 47, 0.08);
}

.member-avatar:first-child,
.expense-mini-avatar:first-child {
  margin-left: 0;
}

.member-avatar-small {
  width: 54rpx;
  height: 54rpx;
  font-size: 20rpx;
  flex: none;
}

.expense-mini-avatar {
  width: 40rpx;
  height: 40rpx;
  margin-left: -8rpx;
  font-size: 16rpx;
}

.member-tone-owner {
  background: linear-gradient(135deg, #2ebd4f 0%, #19a43f 100%);
  color: transparent;
  box-shadow: inset 0 0 0 10rpx #fffdf7, 0 6rpx 12rpx rgba(41, 44, 47, 0.08);
}

.member-avatar-small.member-tone-owner {
  box-shadow: inset 0 0 0 8rpx #fffdf7;
}

.expense-mini-avatar.member-tone-owner {
  box-shadow: inset 0 0 0 6rpx #fffdf7;
}

.member-tone-coral {
  background: #ffc4bc;
}

.member-tone-blue {
  background: #9dcbef;
}

.member-tone-mint {
  background: #86d0ba;
}

.member-tone-gold {
  background: #f4d98a;
}

.avatar-owner-badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  border: 2rpx solid #fffdf7;
  background: #ffe38d;
  color: #70561f;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.member-info-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.member-copy {
  flex: 1;
  min-width: 0;
}

.member-summary {
  color: #27313a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.claim-summary {
  margin-top: 10rpx;
  color: #a96c12;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.3;
}

.member-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: none;
}

.action-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.action-pill-outline {
  border: 2rpx solid #b9ead7;
  background: #e8f8f0;
  color: #188460;
}

.action-pill-soft {
  background: #dff0ff;
  color: #3973ae;
}

.member-manager {
  padding: 22rpx 24rpx;
  background: rgba(255, 255, 255, 0.76);
}

.manager-note {
  color: #75828d;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.5;
}

.manager-list {
  margin-top: 14rpx;
}

.manager-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 1rpx dashed #e8ddca;
}

.manager-row:first-child {
  padding-top: 0;
  border-top: 0;
}

.manager-member {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.manager-copy {
  flex: 1;
  min-width: 0;
}

.manager-name {
  color: #26313a;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.2;
}

.manager-sub {
  margin-top: 6rpx;
  color: #7b8791;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.claim-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  flex: none;
}

.claim-pill-pending {
  background: #fff2d9;
  color: #a76a0f;
}

.claim-pill-claimed {
  background: #e6f6ef;
  color: #188460;
}

.member-adder {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.manager-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 2rpx solid #eadfce;
  background: rgba(255, 250, 246, 0.9);
  box-sizing: border-box;
  color: #26313a;
  font-size: 26rpx;
  font-weight: 800;
}

.manager-add-btn {
  width: 160rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 22rpx;
  background: #2c3640;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.fund-card {
  padding: 22rpx 24rpx;
  border-style: dashed;
  background: rgba(255, 255, 255, 0.76);
  color: #74808a;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.55;
}

.expense-list {
  margin-top: 2rpx;
}

.expense-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(101, 95, 85, 0.08);
}

.expense-icon {
  position: relative;
  width: 66rpx;
  height: 66rpx;
  border-radius: 24rpx;
  border: 4rpx solid #f2c558;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #25313b;
  flex: none;
  background: #fffdf6;
}

.expense-icon.member-tone-owner {
  box-shadow: inset 0 0 0 12rpx #fffdf7;
}

.expense-content {
  flex: 1;
  min-width: 0;
}

.expense-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.expense-maincopy {
  flex: 1;
  min-width: 0;
}

.expense-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.expense-title {
  color: #27313a;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.2;
}

.expense-edit-tag {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #edf2f6;
  color: #6d7b87;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.expense-time {
  color: #98a4ae;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.expense-amount {
  color: #27313a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.05;
  flex: none;
}

.expense-flow {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.expense-flow-label {
  color: #73808c;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.empty-card {
  padding: 30rpx 24rpx;
  border-style: dashed;
  background: rgba(255, 255, 255, 0.74);
  color: #7a8790;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.5;
  text-align: center;
}

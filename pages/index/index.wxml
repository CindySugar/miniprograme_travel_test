<navigation-bar title="旅行AA记账" back="{{false}}" color="#1f2a37" background="transparent"></navigation-bar>
<view class="home-page">
  <view class="home-shell">
    <view class="hero-card">
      <view class="hero-copy">
        <view class="hero-badge">一起出去玩，也要软软地算清。</view>
        <view class="hero-title">创建一次猫猫组队</view>
        <view class="hero-desc">邀请同行猫猫加入，大家各自记录垫付账单，最后自动算清。</view>
      </view>
      <view class="hero-illustration">
        <image class="hero-image" src="/assets/travel-cat.png" mode="aspectFit"></image>
      </view>
    </view>

    <button class="create-entry" bindtap="goCreateTravel">创建组队</button>
    <view class="entry-hint">加入队伍请打开好友发来的邀请卡片。</view>

    <view class="trip-header">
      <view class="trip-header-title">我的猫猫组队</view>
      <view class="trip-header-right">
        <text class="trip-header-meta">最近 1 个</text>
        <view class="trip-link">查看全部</view>
      </view>
    </view>

    <view class="trip-card" wx:if="{{travels.length}}" bindtap="openTravel" data-id="{{travels[0].id}}">
      <view class="trip-card-top">
        <view>
          <view class="trip-card-kicker">猫猫组队  {{travels[0].displayDate}}</view>
          <view class="trip-card-title">{{travels[0].title}}</view>
        </view>
        <view class="trip-actions">
          <view class="trip-pill trip-pill-muted">归档</view>
          <view class="trip-pill trip-pill-warn">删除</view>
        </view>
      </view>

      <view class="trip-stats">
        <view class="trip-stat">总金额：{{travels[0].summary.totalSpentDisplay}}</view>
        <view class="trip-stat">4 只猫猫</view>
        <view class="trip-stat">1 笔账单</view>
        <view class="trip-stat trip-status">进行中</view>
      </view>

      <view class="trip-card-footer">
        <view class="member-stack">
          <view class="member-badge member-badge-green"></view>
          <view class="member-badge member-badge-coral">老</view>
          <view class="member-badge member-badge-blue">老</view>
          <view class="member-badge member-badge-mint">老</view>
        </view>
        <view class="updated-at">2026-06-15 更新</view>
      </view>
    </view>

    <view wx:else class="trip-card trip-card-empty">
      <view class="trip-card-title">还没有旅行</view>
      <view class="trip-card-empty-text">点上面的按钮创建第一组旅行。</view>
    </view>

    <view class="footer-links">
      <view class="footer-link">关于与鸣谢</view>
      <view class="footer-divider"></view>
      <view class="footer-link">问题反馈</view>
    </view>
  </view>
</view>

@import "../../app.wxss";

page {
  background: linear-gradient(180deg, #fffaf4 0%, #fffdf8 52%, #eef8f2 100%);
}

.manage-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background:
    radial-gradient(rgba(255, 214, 214, 0.42) 3rpx, transparent 3.5rpx) 0 0 / 76rpx 76rpx,
    linear-gradient(180deg, #fffaf4 0%, #fffdf8 58%, #eef8f2 100%);
  padding: 22rpx 28rpx 44rpx;
  box-sizing: border-box;
}

.manage-scroll {
  flex: 1;
  min-height: 0;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.intro-card {
  padding: 24rpx 28rpx;
  border: 2rpx dashed #dccbb7;
  border-radius: 28rpx;
  color: #73808a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.55;
  background: rgba(255, 255, 255, 0.58);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 38rpx;
}

.section-title {
  color: #26313a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.section-meta {
  color: #72808a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.setting-card,
.family-card,
.add-card,
.member-card {
  margin-top: 20rpx;
  border: 2rpx solid #eadfce;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  box-sizing: border-box;
  box-shadow: 0 10rpx 22rpx rgba(100, 94, 84, 0.06);
}

.setting-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 26rpx;
}

.setting-copy {
  flex: 1;
  min-width: 0;
}

.setting-title,
.field-label,
.member-name {
  color: #26313a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.setting-desc {
  margin-top: 10rpx;
  color: #73808a;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.45;
}

.light-button,
.add-button,
.operation-button {
  margin: 0;
  padding: 0;
  border-radius: 22rpx;
  border: 2rpx solid #eadfce;
  background: #fffdf8;
  color: #26313a;
  font-weight: 900;
  box-sizing: border-box;
}

.light-button {
  width: 150rpx;
  height: 62rpx;
  font-size: 23rpx;
  line-height: 58rpx;
  flex: none;
}

.light-button::after,
.add-button::after,
.family-submit::after,
.operation-button::after {
  border: 0;
}

.family-card {
  padding: 28rpx;
}

.choice-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.choice-pill {
  padding: 16rpx 28rpx;
  border: 2rpx solid #eadfce;
  border-radius: 999rpx;
  color: #697680;
  background: rgba(255, 250, 246, 0.88);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.choice-pill-active {
  border-color: #77d5af;
  background: #e8f8f0;
  color: #16825e;
}

.owner-label {
  margin-top: 44rpx;
}

.owner-select-box {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border: 2rpx dashed #dccbb7;
  border-radius: 24rpx;
  color: #7a8791;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.3;
}

.family-submit {
  width: 340rpx;
  height: 78rpx;
  margin: 42rpx auto 0;
  border-radius: 28rpx;
  border: 3rpx solid #26313a;
  background: transparent;
  color: #c9c9c9;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.family-submit-active {
  background: #2c3640;
  color: #ffffff;
}

.family-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 26rpx;
  padding: 20rpx 18rpx;
  border: 2rpx solid #eadfce;
  border-radius: 24rpx;
  background: rgba(255, 250, 246, 0.72);
}

.family-avatars {
  display: flex;
  flex: none;
}

.mini-avatar {
  width: 50rpx;
  height: 50rpx;
  margin-left: -10rpx;
  border: 4rpx solid #fffdf7;
  border-radius: 16rpx;
  background: #ffc4bc;
  color: #26313a;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.mini-avatar:first-child {
  margin-left: 0;
}

.family-copy {
  flex: 1;
  min-width: 0;
}

.family-name {
  color: #26313a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.family-desc {
  margin-top: 8rpx;
  color: #72808a;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}

.remove-pill {
  padding: 12rpx 18rpx;
  border: 2rpx solid #eadfce;
  border-radius: 999rpx;
  color: #26313a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  flex: none;
}

.add-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 24rpx;
}

.add-input,
.name-input {
  box-sizing: border-box;
  border: 2rpx solid #eadfce;
  background: rgba(255, 250, 246, 0.9);
  color: #26313a;
  font-weight: 900;
}

.add-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
}

.add-button {
  width: 126rpx;
  min-width: 126rpx;
  max-width: 126rpx;
  height: 76rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  flex: none;
}

.member-card {
  padding: 22rpx 22rpx 20rpx;
  margin-bottom: 18rpx;
}

.member-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.avatar {
  position: relative;
  width: 78rpx;
  height: 78rpx;
  border: 5rpx solid #fffdf7;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #26313a;
  font-size: 28rpx;
  font-weight: 900;
  flex: none;
  box-shadow: 0 0 0 4rpx #e8ded0;
  box-sizing: border-box;
  overflow: visible;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
}

.member-tone-owner {
  background: linear-gradient(135deg, #2ebd4f 0%, #19a43f 100%);
  color: transparent;
  box-shadow: inset 0 0 0 12rpx #fffdf7, 0 0 0 4rpx #f2cd52;
}

.member-tone-coral {
  background: #ffc4bc;
}

.member-tone-blue {
  background: #9dcbef;
}

.member-tone-mint {
  background: #86d0ba;
}

.member-tone-gold {
  background: #f4d98a;
}

.avatar-mark {
  position: absolute;
  right: -14rpx;
  bottom: -14rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #e8f8f0;
  color: #188460;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-align: center;
  box-shadow: 0 4rpx 8rpx rgba(34, 45, 53, 0.1);
}

.member-main {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.name-input {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.role-pill {
  padding: 11rpx 16rpx;
  border-radius: 999rpx;
  background: #dff0ff;
  color: #2f71ad;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
  flex: none;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 14rpx;
  color: #73808a;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.35;
}

.bind-text {
  color: #2f71ad;
  text-align: right;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.tag-green {
  background: #e6f6ef;
  color: #16825e;
}

.tag-blue {
  background: #dff0ff;
  color: #2f71ad;
}

.tag-red {
  background: #ffebe8;
  color: #e75d50;
}

.tag-yellow {
  background: #fff0bb;
  color: #866012;
}

.operation-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.operation-button {
  flex: 1 1 0;
  min-width: 0;
  height: 56rpx;
  font-size: 22rpx;
  line-height: 52rpx;
  white-space: nowrap;
}

.operation-danger {
  border-color: #ff9d93;
  color: #e75d50;
}

.operation-muted {
  border-color: #e6e1d7;
  color: #c9c9c9;
  background: rgba(255, 255, 255, 0.65);
}

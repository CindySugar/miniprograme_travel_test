@import "../../app.wxss";

.create-page {
  position: relative;
  min-height: 100vh;
  padding: 28rpx 28rpx 0;
  box-sizing: border-box;
  background:
    radial-gradient(rgba(255, 213, 210, 0.42) 4rpx, transparent 4.5rpx) 14rpx 8rpx / 66rpx 66rpx,
    linear-gradient(180deg, #fffaf4 0%, #fffdf8 55%, #eef8f2 100%);
}

.create-scroll {
  height: calc(100vh - 176rpx);
  padding-bottom: 214rpx;
  box-sizing: border-box;
}

.hero-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 248rpx;
  padding: 30rpx 34rpx 28rpx;
  border: 2rpx solid rgba(221, 207, 184, 0.82);
  border-radius: 42rpx;
  background: linear-gradient(125deg, #ffe8a4 0%, #f8f3d5 50%, #d8eefb 100%);
  box-sizing: border-box;
  box-shadow: 0 10rpx 24rpx rgba(96, 91, 78, 0.06);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-badge {
  display: inline-flex;
  padding: 13rpx 25rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #6f7c86;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-title {
  margin-top: 18rpx;
  color: #26313a;
  font-size: 47rpx;
  font-weight: 900;
  line-height: 1.08;
}

.hero-subtitle {
  margin-top: 20rpx;
  color: #6d7b86;
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 900;
}

.hero-image {
  width: 156rpx;
  height: 156rpx;
  flex: none;
}

.tabs {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 8rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid #eadfce;
  box-sizing: border-box;
}

.tab {
  flex: 1;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 23rpx;
  background: transparent;
  color: #74818a;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 68rpx;
  text-align: center;
}

.tab::after {
  border: 0;
}

.tab-active {
  background: #28343d;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(40, 52, 61, 0.14);
}

.tab-panel {
  padding-bottom: 30rpx;
}

.form-card {
  margin-top: 24rpx;
  padding: 28rpx 28rpx;
  border-radius: 34rpx;
  border: 2rpx solid #eadfce;
  background: rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  box-shadow: none;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  color: #26313a;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.2;
}

.section-desc {
  margin-top: 7rpx;
  color: #75838d;
  font-size: 25rpx;
  line-height: 1.36;
  font-weight: 900;
}

.section-meta {
  flex: none;
  color: #798790;
  font-size: 25rpx;
  font-weight: 900;
}

.head-tags {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex: none;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #d8edf9;
  color: #2f79aa;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.tag-green {
  background: #e6f6ef;
  color: #178160;
}

.field {
  margin-top: 24rpx;
}

.field:first-child {
  margin-top: 0;
}

.label {
  display: block;
  margin-bottom: 13rpx;
  color: #72808a;
  font-size: 27rpx;
  font-weight: 900;
}

.input,
.textarea,
.picker-field {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #eadfce;
  border-radius: 24rpx;
  background: rgba(255, 250, 246, 0.88);
  color: #26313a;
  font-size: 28rpx;
  font-weight: 800;
}

.input {
  height: 78rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 138rpx;
  padding: 22rpx 24rpx;
  line-height: 1.45;
}

.picker-field {
  height: 78rpx;
  padding: 0 24rpx;
  line-height: 78rpx;
  font-size: 30rpx;
}

.owner-row {
  display: flex;
  gap: 28rpx;
  margin-top: 20rpx;
  padding: 18rpx 20rpx 20rpx;
  border: 2rpx solid #eadfce;
  border-radius: 28rpx;
  background: rgba(255, 250, 246, 0.78);
  box-sizing: border-box;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 96rpx;
  min-width: 96rpx;
  max-width: 96rpx;
  margin: 0;
  padding: 2rpx 0 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-sizing: border-box;
  padding-top: 2rpx;
  flex: none;
}

.avatar-wrap::after {
  border: 0;
}

.avatar-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin: 0 auto;
  border: 5rpx solid #28343d;
  border-radius: 26rpx;
  overflow: hidden;
  background: #fff0bd;
  color: #28343d;
  text-align: center;
  box-shadow: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.avatar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  min-width: 86rpx;
  max-width: 86rpx;
  height: 36rpx;
  margin: 8rpx 0 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #ffe8a8;
  color: #6f5729;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.owner-main {
  flex: 1;
  min-width: 0;
}

.add-member {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.add-input {
  flex: 1;
  min-width: 0;
}

.add-btn {
  width: 118rpx;
  height: 78rpx;
  margin: 0;
  border-radius: 24rpx;
  border: 2rpx solid #eadfce;
  background: rgba(255, 250, 246, 0.9);
  color: #26313a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.helper-text {
  margin-top: 16rpx;
  color: #72808a;
  font-size: 25rpx;
  line-height: 1.48;
  font-weight: 900;
}

.form-card > .helper-text {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #eaf7f1;
  color: #1d7b61;
}

.family-preview {
  width: 100%;
  padding: 20rpx 22rpx;
  border: 2rpx dashed #dbcbb8;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.5);
  color: #72808a;
  font-size: 27rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.inline-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
}

.advanced-head {
  margin-top: 28rpx;
}

.rules-card {
  margin-top: 18rpx;
  padding: 26rpx 26rpx;
}

.permission-head {
  margin-top: 30rpx;
}

.permission-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.permission-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 118rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid #eadfce;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-sizing: border-box;
}

.permission-item switch {
  flex: none;
}

.permission-item-muted {
  margin-bottom: 32rpx;
}

.permission-copy {
  flex: 1;
  min-width: 0;
}

.permission-title {
  color: #26313a;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.24;
}

.permission-desc {
  margin-top: 10rpx;
  color: #72808a;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.32;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 251, 244, 0.92);
  border-top: 2rpx solid rgba(224, 213, 195, 0.8);
  box-shadow: 0 -14rpx 28rpx rgba(76, 83, 88, 0.06);
  box-sizing: border-box;
  backdrop-filter: blur(10rpx);
}

.create-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  width: 370rpx;
  height: 88rpx;
  padding: 0;
  line-height: 1;
  border-radius: 30rpx;
  background: #28343d;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: 0 16rpx 28rpx rgba(40, 52, 61, 0.2);
}

.avatar-btn::after,
.add-btn::after,
.create-submit::after {
  border: 0;
}

.bottom-note {
  margin-top: 14rpx;
  color: #75838d;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  line-height: 1.35;
}

.team-card {
  margin-top: 26rpx;
  padding-top: 28rpx;
  padding-bottom: 26rpx;
}

.team-divider {
  margin: 24rpx 0 22rpx;
  border-top: 2rpx dashed #dbcbb8;
}

.team-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.team-hint {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #eaf7f1;
  color: #1d7b61;
}

.family-head {
  margin-bottom: 18rpx;
}

.inline-desc {
  margin-top: 0;
}

.detail-card {
  margin-top: 26rpx;
  min-height: 450rpx;
}

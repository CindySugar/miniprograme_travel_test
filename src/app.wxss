page {
  background: #f4f7fb;
  color: #13202f;
  font-size: 28rpx;
}

button {
  border-radius: 12rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  background: #ffffff;
  border: 1rpx solid #dde6f2;
  border-radius: 12rpx;
  padding: 28rpx;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: #607086;
  font-size: 26rpx;
  line-height: 1.5;
}

.section {
  margin-top: 20rpx;
  background: #ffffff;
  border: 1rpx solid #dde6f2;
  border-radius: 12rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-meta {
  color: #75859a;
  font-size: 24rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row-wrap {
  flex-wrap: wrap;
}

.muted {
  color: #75859a;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e9f2ff;
  color: #2f67d9;
  font-size: 22rpx;
}

.chip-soft {
  background: #edf7f4;
  color: #0e7b68;
}

.chip-warn {
  background: #fff4e5;
  color: #b36a00;
}

.primary-btn {
  background: #186cff;
  color: #ffffff;
}

.secondary-btn {
  background: #edf2f8;
  color: #24313f;
}

.ghost-btn {
  background: transparent;
  color: #186cff;
  padding-left: 0;
  padding-right: 0;
}

.field {
  margin-top: 16rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #4a5a6d;
  font-size: 24rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d7e1ee;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 20rpx;
  font-size: 28rpx;
}

.textarea {
  min-height: 140rpx;
}

.list {
  margin-top: 16rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf1f6;
}

.list-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.list-main {
  flex: 1;
  min-width: 0;
}

.title-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  font-weight: 600;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #0e7b68;
}

.amount-negative {
  color: #d04b37;
}

.subtext {
  margin-top: 8rpx;
  color: #75859a;
  font-size: 24rpx;
  line-height: 1.45;
}
